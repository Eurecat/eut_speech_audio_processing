[run]
source = audio_stream_manager
omit = 
    */test/*
    */tests/*
    setup.py
    __pycache__/*
    .pytest_cache/*

[report]
exclude_lines =
    pragma: no cover
    def __repr__
    raise AssertionError
    raise NotImplementedError
    if __name__ == .__main__.:

[html]
directory = htmlcov

[xml]
output = coverage.xml