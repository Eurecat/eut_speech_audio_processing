BUILT_IMAGE=eut_audio_vulcanexus:jazzy
DOCKER_RUNTIME=nvidia
ROS_DOMAIN_ID=12
HF_TOKEN=your_huggingface_token_here

# Log retention: number of log sessions to keep on each container start.
# Use -1 to never delete logs, or any positive integer (e.g. 2, 10).
BUILD_LOGS_TO_KEEP=2
RUNTIME_LOGS_TO_KEEP=2