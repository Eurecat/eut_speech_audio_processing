<!-- Cyclone DDS configuration for Tiago Pro Ethernet -->
<CycloneDDS>
  <Domain>
    <General>
      <AllowMulticast>false</AllowMulticast>
      <Interfaces>
        <!-- Auto-select active non-loopback interface to avoid host-specific NIC names -->
        <NetworkInterface autodetermine="true" priority="2" presence_required="true"/>
        <NetworkInterface name="lo" priority="0"/>
      </Interfaces>
    </General>

    <Discovery>
      <ParticipantIndex>auto</ParticipantIndex>
      <MaxAutoParticipantIndex>500</MaxAutoParticipantIndex>
      <Peers>
        <Peer Address="localhost"/>
        <Peer Address="10.68.0.1"/> <!-- robot IP over Tiago Pro Ethernet -->
      </Peers>
    </Discovery>
  </Domain>
</CycloneDDS>
